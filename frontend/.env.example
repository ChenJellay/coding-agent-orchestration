# =============================================================================
# Agenti-Helix Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# URL of the Agenti-Helix control-plane API server.
# Must match the host/port where the backend is running.
VITE_API_BASE_URL=http://127.0.0.1:8001

# Intent compiler: set to "true" when your backend LLM/inference is configured (see README).
# When false or unset, the dashboard uses the deterministic demo compiler (fast, no model).
# VITE_INTENT_USE_LLM=true

# Bearer token for authenticated API calls (D1).
# Must match AGENTI_HELIX_API_KEY set on the backend.
# Leave unset for local development (auth is bypassed when backend has no key).
# VITE_API_KEY=your-secret-editor-token
