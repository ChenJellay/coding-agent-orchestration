# =============================================================================
# Agenti-Helix Backend — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — Repository
# ---------------------------------------------------------------------------
# Absolute path to the repository the agents will read/edit.
# For local dev, point this at the included demo-repo.
AGENTI_HELIX_REPO_ROOT=/path/to/your/repo

# ---------------------------------------------------------------------------
# Inference — all agents use one local MLX model (default)
# ---------------------------------------------------------------------------
# Apple Silicon + mlx_lm. Set QWEN_MODEL_PATH to a local directory or a
# Hugging Face MLX repo id (e.g. mlx-community/Qwen3.5-9B-MLX-4bit).
# If unset, the runtime falls back to that default HF id.
QWEN_MODEL_PATH=/path/to/mlx-model

# Hard ceiling passed to mlx_lm.generate when max_tokens is omitted (default 262144).
# Generation normally stops at EOS before this is reached.
# AGENTI_HELIX_MLX_MAX_TOKENS=262144

# Default for every agent (coder, judge, intent compiler, Supreme Court, memory summarizer).
AGENTI_HELIX_BACKEND_TYPE=mlx_local

# ---------------------------------------------------------------------------
# Optional — OpenAI-compatible HTTP API (only if you set backend to openai)
# ---------------------------------------------------------------------------
# Not used when AGENTI_HELIX_BACKEND_TYPE=mlx_local (recommended for offline / local-only).
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# AGENTI_HELIX_BACKEND_TYPE=openai

# ---------------------------------------------------------------------------
# Authentication (D1)
# ---------------------------------------------------------------------------
# Set AGENTI_HELIX_API_KEY to enable Bearer token authentication.
# Leave unset for local development (auth is bypassed in dev mode).
# AGENTI_HELIX_API_KEY=your-secret-editor-token

# Optional read-only viewer token (GET endpoints only).
# AGENTI_HELIX_VIEWER_API_KEY=your-viewer-token

# Set to "true" to enforce auth even when no API key is configured.
# AGENTI_HELIX_AUTH_ENABLED=false

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
# Path for the structured event log (JSONL). Defaults to
# $AGENTI_HELIX_REPO_ROOT/.agenti_helix/logs/events.jsonl
# AGENTI_HELIX_LOG_PATH=/custom/path/events.jsonl

# Session identifier embedded in every event log entry.
# AGENTI_HELIX_SESSION_ID=dev-session-1

# Set to "true" to suppress all event log writes (useful in tests).
# AGENTI_HELIX_DISABLE_LOGGING=false

# Write full rendered prompt + raw model output to events.jsonl (kind=llm_trace).
# Disable in production if logs grow too large. Frontend "LLM I/O" panel reads these.
# AGENTI_HELIX_LLM_TRACE=true
# Max characters per prompt/output/parsed field before truncation (default 250000).
# AGENTI_HELIX_LLM_TRACE_MAX_CHARS=250000

# ---------------------------------------------------------------------------
# Git Integration (D — §4.6)
# ---------------------------------------------------------------------------
# Set to "true" to make the merge endpoint create real git commits.
# Leave unset for simulated merges (safe for demo/dev).
# AGENTI_HELIX_GIT_COMMIT_ENABLED=false
